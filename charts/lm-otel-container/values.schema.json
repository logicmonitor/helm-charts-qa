{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["portalName", "clusterIdentity", "auth"],
  "properties": {
    "portalName": {
      "type": "string",
      "minLength": 1
    },
    "clusterName": {
      "type": "string"
    },
    "clusterIdentity": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["explicit", "cloudAuto"]
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["existingSecret"],
      "properties": {
        "existingSecret": { "type": "string", "minLength": 1 },
        "secretKey": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "clusterIdentity": {
            "properties": { "mode": { "const": "explicit" } },
            "required": ["mode"]
          }
        },
        "required": ["clusterIdentity"]
      },
      "then": {
        "properties": {
          "clusterName": { "type": "string", "minLength": 1 }
        },
        "required": ["clusterName"]
      }
    }
  ]
}
